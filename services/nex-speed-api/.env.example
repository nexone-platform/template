# NexSpeed TMS Backend Configuration
# Copy this file to .env and modify as needed

# Server
SERVER_PORT=8080

# Database (PostgreSQL)
# If DB is unavailable, API runs in mock mode automatically
DB_HOST=localhost
DB_PORT=5432
DB_USER=nexspeed
DB_PASSWORD=nexspeed123
DB_NAME=nexspeed_tms
DB_SSLMODE=disable

# CORS
CORS_ORIGIN=http://localhost:3100
